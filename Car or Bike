import java.util.*;
import java.lang.*;
import java.io.*;
class Codechef
{
	public static void main (String[] args) throws java.lang.Exception
	{
		Scanner sc=new Scanner(System.in);
		int n=sc.nextInt();
		for(int i=0;i<n;i++)
		{
		    int bike=sc.nextInt();
		    int car=sc.nextInt();
		    if(bike<car)
		       System.out.println("BIKE");
		     else if(car<bike)
		        System.out.println("CAR");
		     else if(car==bike)
		        System.out.println("SAME");
		}
	}
}
Input:
3
1 5
4 2
6 6

Output:
BIKE
CAR
SAME
Time complexity:O(N)
Space complexity:O(1)
