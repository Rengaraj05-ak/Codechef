import java.util.*;
import java.lang.*;
import java.io.*;
class Codechef
{
	public static void main (String[] args) throws java.lang.Exception
	{
	    Scanner sc=new Scanner(System.in);
	    int n=sc.nextInt();
	    for(int i=0;i<n;i++)
	    {
	    int a=sc.nextInt();
	    int b=sc.nextInt();
	    int x=sc.nextInt();
	    int y=sc.nextInt();
	    int prodt1=a*b;
	    int prodt2=x*y;
	    if(prodt2>=prodt1)
	        System.out.println("Yes");
	    else
	        System.out.println("No");
	    }
	}
}
